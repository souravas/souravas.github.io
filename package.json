{
  "name": "souravas-integrated",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:integrated": "npm run build && npm run preview",
    "build": "npm run build:v3 && npm run integrate",
    "build:v3": "cd v3 && npm run build",
    "integrate": "node scripts/integrate.js",
    "preview": "vite preview --outDir dist --port 3002",
    "deploy": "npm run build && gh-pages -d dist",
    "clean": "rm -rf dist v3/dist"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "vite": "^6.2.0"
  }
}
